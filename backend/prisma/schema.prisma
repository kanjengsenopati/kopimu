// Prisma Schema for KSU (Koperasi Serba Usaha)
// Standard: SAK EP (Accounting), Multi-Warehouse (Retail), BOM (Manufacturing)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- CORE & AUTH ---

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  member    Member?  @relation(fields: [memberId], references: [id])
  memberId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  isAdmin     Boolean          @default(false)
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique // e.g., CREATE_LOAN, APPROVE_LOAN
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  scope        String? // GLOBAL, BRANCH, PERSONAL
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model ConfigSHU {
  id         String   @id @default(uuid())
  key        String   @unique // JASA_MODAL, JASA_ANGGOTA, CADANGAN, etc.
  percentage Float    // 0 - 100
  updatedAt  DateTime @updatedAt
}

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model Member {
  id              String      @id @default(uuid())
  nik             String      @unique
  nama            String
  alamat          String?
  telepon         String?
  status          String      @default("AKTIF")
  user            User?
  loans           Loan[]
  savings         Saving[]
  retailPurchases Sale[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// --- ACCOUNTING (SAK EP - Double Entry) ---

model Account {
  id            String         @id @default(uuid())
  code          String         @unique // e.g., 101.01
  name          String
  category      String         // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  type          String         // CASH, BANK, RECEIVABLE, PAYABLE, etc.
  journalEntries JournalEntry[]
}

model Journal {
  id          String         @id @default(uuid())
  date        DateTime       @default(now())
  description String
  reference   String?        // Link to transaction ID (Loan, Sale, etc.)
  entries     JournalEntry[]
  createdAt   DateTime       @default(now())
}

model JournalEntry {
  id        String   @id @default(uuid())
  journalId String
  accountId String
  debit     Decimal  @default(0) @db.Decimal(18, 2)
  credit    Decimal  @default(0) @db.Decimal(18, 2)
  journal   Journal  @relation(fields: [journalId], references: [id])
  account   Account  @relation(fields: [accountId], references: [id])
}

// --- COOPERATIVE (LENDING & SAVINGS) ---

model LoanProduct {
  id           String   @id @default(uuid())
  name         String
  interestRate Float    // Annual interest
  maxTenor     Int      // in months
  maxAmount    Decimal  @db.Decimal(18, 2)
  loans        Loan[]
}

model Loan {
  id            String      @id @default(uuid())
  memberId      String
  productId     String
  amount        Decimal     @db.Decimal(18, 2)
  interestRate  Float
  tenor         Int
  status        String      @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  notes         String?
  member        Member      @relation(fields: [memberId], references: [id])
  product       LoanProduct @relation(fields: [productId], references: [id])
  installments  Installment[]
  createdAt     DateTime    @default(now())
}

model Installment {
  id          String   @id @default(uuid())
  loanId      String
  periodNo    Int
  principal   Decimal  @db.Decimal(18, 2)
  interest    Decimal  @db.Decimal(18, 2)
  dueDate     DateTime
  paidDate    DateTime?
  status      String   @default("UNPAID") // UNPAID, PAID, LATE
  loan        Loan     @relation(fields: [loanId], references: [id])
}

model Saving {
  id        String   @id @default(uuid())
  memberId  String
  type      String   // POKOK, WAJIB, SUKARELA
  amount    Decimal  @db.Decimal(18, 2)
  date      DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id])
}

// --- RETAIL (MULTI-WAREHOUSE) ---

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  location  String?
  stocks    Stock[]
  sales     Sale[]
  moveFrom  StockMovement[] @relation("source")
  moveTo    StockMovement[] @relation("target")
}

model Product {
  id          String         @id @default(uuid())
  sku         String         @unique
  name        String
  category    String?
  buyPrice    Decimal        @db.Decimal(18, 2)
  sellPrice   Decimal        @db.Decimal(18, 2)
  stocks      Stock[]
  saleItems   SaleItem[]
  bom         BOM[]
  production  Production[]
}

model Stock {
  id          String    @id @default(uuid())
  productId   String
  warehouseId String
  qty         Float
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  @@unique([productId, warehouseId])
}

model Sale {
  id          String     @id @default(uuid())
  warehouseId String
  cashierId   String?
  memberId    String?
  total       Decimal    @db.Decimal(18, 2)
  date        DateTime   @default(now())
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])
  member      Member?    @relation(fields: [memberId], references: [id])
  items       SaleItem[]
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  productId String
  qty       Float
  price     Decimal @db.Decimal(18, 2)
  subtotal  Decimal @db.Decimal(18, 2)
  sale      Sale    @relation(fields: [saleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model StockMovement {
  id          String    @id @default(uuid())
  productId   String
  fromId      String?
  toId        String?
  qty         Float
  type        String    // ADJ, TRANSFER, PRODUCTION, SALE
  date        DateTime  @default(now())
  source      Warehouse? @relation("source", fields: [fromId], references: [id])
  target      Warehouse? @relation("target", fields: [toId], references: [id])
}

// --- MANUFACTURING ---

model BOM {
  id          String   @id @default(uuid())
  productId   String   // Finished good
  materialId  String   // Raw material
  qtyNeeded   Float
  product     Product  @relation(fields: [productId], references: [id])
}

model Production {
  id          String    @id @default(uuid())
  productId   String
  warehouseId String    // Target warehouse for finished good
  targetQty   Float
  status      String    @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED
  startDate   DateTime?
  endDate     DateTime?
  product     Product   @relation(fields: [productId], references: [id])
}
